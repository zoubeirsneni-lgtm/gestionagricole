rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "zoubeirsneni@gmail.com" && request.auth.token.email_verified == true);
    }

    function isAdmin() {
      return isSuperAdmin() || (isAuthenticated() && getUserData().role == 'admin');
    }

    function isViewer() {
      return isAuthenticated() && (getUserData().role == 'viewer' || isAdmin());
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    function isValidUser(data) {
      return data.email is string && 
             data.role in ["super_admin", "admin", "viewer"] &&
             data.keys().hasOnly(['email', 'displayName', 'role', 'createdAt']);
    }

    // User management
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only the Super Admin (email verified) or the initial bootstrapped admin can manage roles
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /animals/{animalId} {
      allow read: if isViewer();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /health_records/{recordId} {
      allow read: if isViewer();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /reproduction/{reproId} {
      allow read: if isViewer();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /stocks/{stockId} {
      allow read: if isViewer();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
