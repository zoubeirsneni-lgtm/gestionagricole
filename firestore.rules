rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isValidAnimal(data) {
      return data.tagId is string && data.tagId.size() > 0 &&
             data.species in ["Bovin", "Ovin", "Caprin", "Porcin", "Volaille"] &&
             data.gender in ["Mâle", "Femelle"] &&
             data.status in ["Actif", "Vendu", "Décédé"] &&
             data.ownerId == request.auth.uid;
    }

    match /animals/{animalId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidAnimal(request.resource.data);
      allow update: if isDocOwner() && isValidAnimal(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /health_records/{recordId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /reproduction/{reproId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isDocOwner();
    }

    match /stocks/{stockId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isDocOwner();
    }
  }
}
